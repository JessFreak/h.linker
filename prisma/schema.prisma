datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum HackathonStatus {
  DRAFT
  REGISTRATION
  ACTIVE
  FINISHED
}

enum UserTeamStatus {
  PENDING
  ACCEPTED
  REJECTED
  LEFT
}

model Role {
  name       String     @id
  usersTeams UserTeam[]

  @@map("roles")
}

model Category {
  name                 String              @id
  usersCategories      UserCategory[]
  hackathonsCategories HackathonCategory[]

  @@map("categories")
}

model User {
  id             String  @id @default(uuid())
  email          String  @unique
  username       String  @unique
  firstName      String  @map("first_name")
  lastName       String? @map("last_name")
  githubId       String? @unique @map("github_id")
  githubUsername String? @unique @map("github_username")
  bio            String?
  avatarUrl      String? @map("avatar_url")
  password       String

  ownedTeams        Team[]         @relation("TeamLeader")
  createdHackathons Hackathon[]    @relation("HackathonCreator")
  memberships       UserTeam[]
  skills            UserCategory[]
  juryRoles         Jury[]

  @@map("users")
}

model Team {
  id                String  @id @default(uuid())
  name              String
  leaderId          String  @map("leader_id")
  leader            User    @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Cascade)
  description       String?
  communicationLink String? @map("communication_link")

  members        UserTeam[]
  participations Participation[]

  @@map("teams")
}

model UserTeam {
  id       String         @id @default(uuid())
  userId   String         @map("user_id")
  teamId   String         @map("team_id")
  roleName String         @map("role_name")
  status   UserTeamStatus @default(PENDING)
  type     String?
  message  String?
  created  DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleName], references: [name])

  @@map("users_teams")
}

model Hackathon {
  id          String          @id @default(uuid())
  creatorId   String          @map("creator_id")
  title       String
  description String?
  status      HackathonStatus @default(DRAFT)
  startDate   DateTime        @map("start_date")
  endDate     DateTime        @map("end_date")
  imageUrl    String?         @map("image_url")

  creator        User                @relation("HackathonCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  categories     HackathonCategory[]
  criteria       Criterion[]
  jury           Jury[]
  participations Participation[]

  @@map("hackathons")
}

model UserCategory {
  userId   String   @map("user_id")
  category String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cat      Category @relation(fields: [category], references: [name], onDelete: Cascade)

  @@id([userId, category])
  @@map("users_categories")
}

model HackathonCategory {
  hackathonId String    @map("hackathon_id")
  category    String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  cat         Category  @relation(fields: [category], references: [name], onDelete: Cascade)

  @@id([hackathonId, category])
  @@map("hackathons_categories")
}

model Participation {
  id            String  @id @default(uuid())
  teamId        String  @map("team_id")
  hackathonId   String  @map("hackathon_id")
  githubRepoUrl String? @map("github_repo_url")
  finalScore    Float   @default(0) @map("final_score")

  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  scores    Score[]
  reviews   Review[]

  @@unique([teamId, hackathonId])
  @@map("participations")
}

model Criterion {
  id          String @id @default(uuid())
  hackathonId String @map("hackathon_id")
  name        String
  weight      Float
  maxValue    Int    @default(10) @map("max_value")

  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  scores    Score[]

  @@map("criteria")
}

model Jury {
  id          String @id @default(uuid())
  userId      String @map("user_id")
  hackathonId String @map("hackathon_id")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  scores    Score[]
  reviews   Review[]

  @@unique([hackathonId, userId])
  @@map("jury")
}

model Score {
  id              String @id @default(uuid())
  juryId          String @map("jury_id")
  participationId String @map("participation_id")
  criterionId     String @map("criterion_id")
  value           Float

  jury          Jury          @relation(fields: [juryId], references: [id], onDelete: Cascade)
  participation Participation @relation(fields: [participationId], references: [id], onDelete: Cascade)
  criterion     Criterion     @relation(fields: [criterionId], references: [id], onDelete: Cascade)

  @@map("scores")
}

model Review {
  id              String  @id @default(uuid())
  participationId String  @map("participation_id")
  juryId          String  @map("jury_id")
  summary         String
  strengths       String?
  weaknesses      String?

  participation Participation @relation(fields: [participationId], references: [id], onDelete: Cascade)
  jury          Jury          @relation(fields: [juryId], references: [id], onDelete: Cascade)

  @@unique([juryId, participationId])
  @@map("reviews")
}
